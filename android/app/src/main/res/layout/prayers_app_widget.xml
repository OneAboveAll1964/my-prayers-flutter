<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="@android:color/transparent">

    <TextView
        android:id="@+id/widget_arabic"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="20sp"
        android:lineSpacingMultiplier="1.5"
        android:textDirection="rtl"
        android:layoutDirection="rtl"
        android:textColor="#15171A"
        android:fontFamily="@font/amiri_quran_regular"
        android:textAlignment="textStart"
        android:maxLines="3"
        android:ellipsize="end"
        android:text="بِسْمِ ٱللَّهِ ٱلرَّحْمَـٰنِ ٱلرَّحِيمِ" />

    <TextView
        android:id="@+id/widget_translation"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:textSize="12.5sp"
        android:textColor="#5A5F66"
        android:lineSpacingMultiplier="1.35"
        android:maxLines="2"
        android:ellipsize="end"
        android:text="In the name of Allah, the Entirely Merciful, the Especially Merciful." />

    <TextView
        android:id="@+id/widget_reference"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:textSize="10.5sp"
        android:textColor="#898E95"
        android:textStyle="italic"
        android:maxLines="1"
        android:ellipsize="end"
        android:text="Al-Fātiḥah 1:1" />
</LinearLayout>
