<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/transparent">

    <LinearLayout
        android:id="@+id/widget_card_default"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="10dp"
        android:visibility="visible"
        android:background="@android:color/transparent">

        <TextView
            android:id="@+id/widget_arabic"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="18sp"
            android:lineSpacingMultiplier="1.25"
            android:textDirection="rtl"
            android:layoutDirection="rtl"
            android:textColor="#15171A"
            android:textAlignment="textStart"
            android:maxLines="3"
            android:ellipsize="end"
            android:text="بِسْمِ ٱللَّهِ ٱلرَّحْمَـٰنِ ٱلرَّحِيمِ" />

        <TextView
            android:id="@+id/widget_translation"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textSize="12sp"
            android:textColor="#5A5F66"
            android:lineSpacingMultiplier="1.2"
            android:maxLines="2"
            android:ellipsize="end"
            android:text="In the name of Allah, the Entirely Merciful." />

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <TextView
            android:id="@+id/widget_reference"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textSize="10sp"
            android:textColor="#898E95"
            android:textStyle="italic"
            android:maxLines="1"
            android:ellipsize="end"
            android:text="Al-Fātiḥah 1:1" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/widget_card_centered"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="10dp"
        android:gravity="center"
        android:visibility="gone"
        android:background="@android:color/transparent">

        <TextView
            android:id="@+id/widget_arabic_centered"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="18sp"
            android:lineSpacingMultiplier="1.25"
            android:textDirection="rtl"
            android:layoutDirection="rtl"
            android:textColor="#F1F3F5"
            android:textAlignment="center"
            android:gravity="center"
            android:maxLines="3"
            android:ellipsize="end"
            android:text="بِسْمِ ٱللَّهِ ٱلرَّحْمَـٰنِ ٱلرَّحِيمِ" />

        <TextView
            android:id="@+id/widget_translation_centered"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:textSize="13sp"
            android:textColor="#F1F3F5"
            android:lineSpacingMultiplier="1.25"
            android:textAlignment="center"
            android:gravity="center"
            android:maxLines="3"
            android:ellipsize="end"
            android:text="In the name of Allah, the Entirely Merciful." />

        <TextView
            android:id="@+id/widget_reference_centered"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:textSize="10.5sp"
            android:textColor="#B6BBC2"
            android:textStyle="italic"
            android:textAlignment="center"
            android:gravity="center"
            android:maxLines="1"
            android:ellipsize="end"
            android:text="Al-Fātiḥah 1:1" />
    </LinearLayout>
</FrameLayout>
