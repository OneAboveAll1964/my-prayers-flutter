<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/config_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/config_background"
    android:fitsSystemWindows="false">

    <LinearLayout
        android:id="@+id/config_header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/config_background"
        android:paddingStart="22dp"
        android:paddingEnd="22dp"
        android:paddingTop="22dp"
        android:paddingBottom="14dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Sakina widget"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="@color/config_text"
            android:layout_marginBottom="4dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Pick what to display and how it should look on your home screen."
            android:textSize="13sp"
            android:textColor="@color/config_text_muted" />
    </LinearLayout>

    <ScrollView
        android:id="@+id/config_scroll"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true"
        android:scrollbars="none"
        android:overScrollMode="never">

        <LinearLayout
            android:id="@+id/config_content"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="22dp"
            android:paddingEnd="22dp"
            android:paddingTop="8dp"
            android:paddingBottom="22dp">

            <TextView style="@style/MpConfigLabel" android:text="Content" />
            <RadioGroup
                android:id="@+id/group_type"
                style="@style/MpSegmentGroup">
                <RadioButton android:id="@+id/type_ayah" style="@style/MpSegmentItem" android:text="Ayah" />
                <RadioButton android:id="@+id/type_azkar" style="@style/MpSegmentItem" android:text="Azkar" />
                <RadioButton android:id="@+id/type_mix" style="@style/MpSegmentItem" android:text="Both" />
            </RadioGroup>

            <TextView style="@style/MpConfigLabel" android:text="Layout" android:layout_marginTop="20dp" />
            <RadioGroup
                android:id="@+id/group_layout"
                style="@style/MpSegmentGroup">
                <RadioButton android:id="@+id/layout_default" style="@style/MpSegmentItem" android:text="Default" />
                <RadioButton android:id="@+id/layout_centered" style="@style/MpSegmentItem" android:text="Centered" />
            </RadioGroup>

            <TextView style="@style/MpConfigLabel" android:text="Background" android:layout_marginTop="20dp" />
            <RadioGroup
                android:id="@+id/group_style"
                style="@style/MpSegmentGroup">
                <RadioButton android:id="@+id/style_transparent" style="@style/MpSegmentItem" android:text="Clear" />
                <RadioButton android:id="@+id/style_tinted" style="@style/MpSegmentItem" android:text="Tinted" />
                <RadioButton android:id="@+id/style_solid" style="@style/MpSegmentItem" android:text="Solid" />
                <RadioButton android:id="@+id/style_accent" style="@style/MpSegmentItem" android:text="Green" />
            </RadioGroup>

            <TextView style="@style/MpConfigLabel" android:text="Theme" android:layout_marginTop="20dp" />
            <RadioGroup
                android:id="@+id/group_theme"
                style="@style/MpSegmentGroup">
                <RadioButton android:id="@+id/theme_auto" style="@style/MpSegmentItem" android:text="Auto" />
                <RadioButton android:id="@+id/theme_light" style="@style/MpSegmentItem" android:text="Light" />
                <RadioButton android:id="@+id/theme_dark" style="@style/MpSegmentItem" android:text="Dark" />
            </RadioGroup>

            <TextView style="@style/MpConfigLabel" android:text="Arabic font" android:layout_marginTop="20dp" />
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/segment_track_squared"
                android:padding="3dp">
                <RadioGroup
                    android:id="@+id/group_font_row1"
                    android:layout_width="match_parent"
                    android:layout_height="40dp"
                    android:orientation="horizontal"
                    android:background="@null">
                    <RadioButton android:id="@+id/font_uthmanic" style="@style/MpSegmentItem" android:text="Uthmani" />
                    <RadioButton android:id="@+id/font_amiri" style="@style/MpSegmentItem" android:text="Amiri" />
                    <RadioButton android:id="@+id/font_nastaleeq" style="@style/MpSegmentItem" android:text="Nastaleeq" />
                </RadioGroup>
                <RadioGroup
                    android:id="@+id/group_font_row2"
                    android:layout_width="match_parent"
                    android:layout_height="40dp"
                    android:orientation="horizontal"
                    android:layout_marginTop="3dp"
                    android:background="@null">
                    <RadioButton android:id="@+id/font_scheherazade" style="@style/MpSegmentItem" android:text="Scheherazade" />
                    <RadioButton android:id="@+id/font_naskh" style="@style/MpSegmentItem" android:text="Naskh" />
                </RadioGroup>
            </LinearLayout>

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="80dp"
                android:layout_marginTop="10dp"
                android:background="@drawable/font_preview_bg">
                <TextView
                    android:id="@+id/font_preview"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:padding="12dp"
                    android:textSize="22sp"
                    android:textDirection="rtl"
                    android:layoutDirection="rtl"
                    android:textAlignment="center"
                    android:gravity="center"
                    android:maxLines="1"
                    android:ellipsize="none"
                    android:textColor="@color/config_text"
                    android:fontFamily="@font/uthmanic_hafs"
                    android:text="بِسْمِ ٱللَّهِ ٱلرَّحْمَـٰنِ ٱلرَّحِيمِ" />
            </FrameLayout>

            <TextView style="@style/MpConfigLabel" android:text="Text size" android:layout_marginTop="20dp" />
            <RadioGroup
                android:id="@+id/group_size"
                style="@style/MpSegmentGroup">
                <RadioButton android:id="@+id/size_s" style="@style/MpSegmentItem" android:text="Small" />
                <RadioButton android:id="@+id/size_m" style="@style/MpSegmentItem" android:text="Medium" />
                <RadioButton android:id="@+id/size_l" style="@style/MpSegmentItem" android:text="Large" />
            </RadioGroup>

            <TextView style="@style/MpConfigLabel" android:text="Translation" android:layout_marginTop="20dp" />
            <RadioGroup
                android:id="@+id/group_show_tr"
                style="@style/MpSegmentGroup">
                <RadioButton android:id="@+id/show_tr_on" style="@style/MpSegmentItem" android:text="Show" />
                <RadioButton android:id="@+id/show_tr_off" style="@style/MpSegmentItem" android:text="Hide" />
            </RadioGroup>

            <LinearLayout
                android:id="@+id/section_lang"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView style="@style/MpConfigLabel" android:text="Translation language" android:layout_marginTop="20dp" />
                <RadioGroup
                    android:id="@+id/group_lang"
                    style="@style/MpSegmentGroup">
                    <RadioButton android:id="@+id/lang_en" style="@style/MpSegmentItem" android:text="English" />
                    <RadioButton android:id="@+id/lang_ar" style="@style/MpSegmentItem" android:text="Arabic" />
                    <RadioButton android:id="@+id/lang_ku" style="@style/MpSegmentItem" android:text="Kurdish" />
                </RadioGroup>
            </LinearLayout>

            <TextView style="@style/MpConfigLabel" android:text="Reference" android:layout_marginTop="20dp" />
            <RadioGroup
                android:id="@+id/group_show_ref"
                style="@style/MpSegmentGroup">
                <RadioButton android:id="@+id/show_ref_on" style="@style/MpSegmentItem" android:text="Show" />
                <RadioButton android:id="@+id/show_ref_off" style="@style/MpSegmentItem" android:text="Hide" />
            </RadioGroup>

        </LinearLayout>
    </ScrollView>

    <LinearLayout
        android:id="@+id/config_bottom_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/config_background"
        android:paddingStart="22dp"
        android:paddingEnd="22dp"
        android:paddingTop="12dp"
        android:paddingBottom="22dp">

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/config_segment_border"
            android:layout_marginBottom="12dp" />

        <Button
            android:id="@+id/config_randomize"
            style="@style/MpConfigOutlineButton"
            android:text="New random verse" />

        <Button
            android:id="@+id/config_save"
            style="@style/MpConfigPrimaryButton"
            android:layout_marginTop="10dp"
            android:text="Add widget" />
    </LinearLayout>
</LinearLayout>
